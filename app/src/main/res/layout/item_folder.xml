<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:layout_margin="8dp"
	app:cardCornerRadius="20dp"
	app:cardElevation="6dp"
	app:cardBackgroundColor="#F8F9FA"
	android:foreground="?android:attr/selectableItemBackground"
	android:clickable="true"
	android:focusable="true">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:gravity="center"
		android:padding="16dp">

		<!-- Conteneur pour l'icône avec cercle coloré -->
		<FrameLayout
			android:layout_width="80dp"
			android:layout_height="80dp"
			android:layout_gravity="center"
			android:layout_marginBottom="12dp">

			<!-- Cercle de fond coloré -->
			<View
				android:id="@+id/folderBackground"
				android:layout_width="72dp"
				android:layout_height="72dp"
				android:layout_gravity="center"
				android:background="@drawable/bg_folder_modern"/>

			<!-- Image qui va alterner entre logo et photos -->
			<ImageView
				android:id="@+id/folderIcon"
				android:layout_width="64dp"
				android:layout_height="64dp"
				android:layout_gravity="center"
				android:src="@drawable/appicon"
				android:scaleType="centerInside"
				android:padding="8dp"/>
		
		</FrameLayout>

		<!-- Nom du dossier avec style amélioré -->
		<TextView
			android:id="@+id/folderName"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Nom du dossier"
			android:textAlignment="center"
			android:textSize="14sp"
			android:textColor="#2C3E50"
			android:fontFamily="sans-serif-medium"
			android:maxLines="2"
			android:ellipsize="end"
			android:layout_marginBottom="4dp"/>

		<!-- Compteur de recettes -->
		<TextView
			android:id="@+id/recipeCount"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="0 recette"
			android:textAlignment="center"
			android:textSize="11sp"
			android:textColor="#7F8C8D"
			android:fontFamily="sans-serif"
			android:layout_marginBottom="2dp"/>

		<!-- Badge favori (optionnel) -->
		<ImageView
			android:id="@+id/favoriteIcon"
			android:layout_width="16dp"
			android:layout_height="16dp"
			android:src="@android:drawable/btn_star_big_on"
			android:tint="#FFD700"
			android:visibility="gone"
			android:layout_marginTop="2dp"/>

	</LinearLayout>

</androidx.cardview.widget.CardView>
